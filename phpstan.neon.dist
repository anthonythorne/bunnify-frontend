includes:
	- phpstan-baseline.neon

parameters:
	level: 5
	phpVersion: 80200
	paths:
		- bunnify-frontend/bunnify-frontend.php
		- bunnify-frontend/autoload.php
		- bunnify-frontend/uninstall.php
		- bunnify-frontend/src/php
	# szepeviktor/phpstan-wordpress (loaded via phpstan/extension-installer)
	# provides the WordPress function/class/constant stubs.
	treatPhpDocTypesAsCertain: false
	reportUnmatchedIgnoredErrors: false
