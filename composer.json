{
	"name": "anthonythorne/bunnify-frontend",
	"description": "Development environment (linting, static analysis, tests, packaging) for the Bunnify Frontend WordPress plugin.",
	"type": "project",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"wordpress-plugin",
		"cdn",
		"bunnycdn",
		"images",
		"performance"
	],
	"homepage": "https://github.com/anthonythorne/bunnify-frontend",
	"authors": [
		{
			"name": "Anthony Thorne",
			"role": "Developer"
		}
	],
	"support": {
		"issues": "https://github.com/anthonythorne/bunnify-frontend/issues",
		"source": "https://github.com/anthonythorne/bunnify-frontend"
	},
	"require": {
		"php": ">=8.2"
	},
	"require-dev": {
		"squizlabs/php_codesniffer": "^3.9",
		"wp-coding-standards/wpcs": "^3.1",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"phpstan/phpstan": "^1.11",
		"szepeviktor/phpstan-wordpress": "^1.3",
		"phpstan/extension-installer": "^1.4",
		"phpunit/phpunit": "^9.6",
		"brain/monkey": "^2.6",
		"yoast/phpunit-polyfills": "^2.0"
	},
	"autoload": {
		"psr-4": {
			"BunnifyFrontend\\": "bunnify-frontend/src/php/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"BunnifyFrontend\\Tests\\": "tests/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"phpstan/extension-installer": true
		},
		"sort-packages": true,
		"optimize-autoloader": true
	},
	"scripts": {
		"lint": "phpcs",
		"lint:fix": "phpcbf",
		"analyse": "phpstan analyse",
		"test": "phpunit",
		"check": [
			"@lint",
			"@analyse",
			"@test"
		],
		"build": "bash bin/build.sh"
	},
	"scripts-descriptions": {
		"lint": "Check coding standards (PHPCS / WordPress Coding Standards).",
		"lint:fix": "Auto-fix coding-standard violations where possible (PHPCBF).",
		"analyse": "Run static analysis (PHPStan).",
		"test": "Run the PHPUnit test suite.",
		"check": "Run lint, static analysis and tests (the full CI gate).",
		"build": "Assemble a distributable plugin zip in dist/."
	}
}
