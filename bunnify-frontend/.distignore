# Files and folders excluded from the WordPress.org distribution build.
#
# Consumed by 10up/action-wordpress-plugin-deploy (rsync --exclude). Paths are
# relative to this plugin directory. build-tools/vendor/ is intentionally kept:
# it is the runtime autoloader the plugin loads on boot.

# Development documentation (the wp.org listing is built from readme.txt).
README.md

# VCS / packaging metadata.
.distignore
.gitignore
.git
.github

# Composer manifests are not needed at runtime (only vendor/autoload.php is).
build-tools/composer.json
build-tools/composer.lock

# OS / editor cruft.
.DS_Store
Thumbs.db
