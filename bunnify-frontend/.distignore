# Files and folders excluded from the WordPress.org distribution build.
#
# Consumed by 10up/action-wordpress-plugin-deploy (rsync --exclude) and
# bin/build.sh. Paths are relative to this plugin directory. The runtime
# autoloader is the hand-written autoload.php at the plugin root — nothing
# Composer-related ships.

