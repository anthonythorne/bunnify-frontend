# Normalise line endings.
* text=auto eol=lf

*.php text
*.md   text
*.txt  text
*.yml  text
*.neon text

# Keep binary assets intact.
*.png  binary
*.jpg  binary
*.gif  binary
*.zip  binary

# Exclude development-only paths from `git archive` exports.
# (Distribution to WordPress.org is driven by bunnify-frontend/.distignore,
#  but these keep `git archive` tarballs lean too.)
/.github            export-ignore
/.vscode            export-ignore
/docs               export-ignore
/tests              export-ignore
/bin                export-ignore
/.editorconfig      export-ignore
/.gitattributes     export-ignore
/.gitignore         export-ignore
/composer.json      export-ignore
/composer.lock      export-ignore
/phpcs.xml.dist     export-ignore
/phpstan.neon.dist  export-ignore
/phpstan-baseline.neon export-ignore
/phpunit.xml.dist   export-ignore
